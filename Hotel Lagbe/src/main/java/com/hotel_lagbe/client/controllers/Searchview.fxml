<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #FFFFFF;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel_lagbe.client.controllers.SearchController">

    <children>

        <!-- Top Navbar -->
        <AnchorPane layoutY="-1.0" prefHeight="78.0" prefWidth="800.0"
                    style="-fx-background-color: #FFFFFF;">
            <children>
                <ImageView fitHeight="97.0" fitWidth="118.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/com/hotel_lagbe/views/logoo.png" />   <!-- Better path -->
                    </image>
                </ImageView>
                <Button layoutX="681.0" layoutY="29.0" mnemonicParsing="false"
                        prefHeight="30.0" prefWidth="81.0"
                        style="-fx-background-color: #000080; -fx-background-radius: 5; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Chat">
                    <font>
                        <Font name="Nirmala UI Bold" size="15.0" />
                    </font>
                </Button>
            </children>
        </AnchorPane>

        <!-- Search Bar Section -->
        <AnchorPane layoutY="77.0" prefHeight="110.0" prefWidth="800.0"
                    style="-fx-background-color: #FAF9F6;">
            <children>

                <Label layoutX="38.0" layoutY="11.0" prefHeight="34.0" prefWidth="145.0"
                       style="-fx-background-color: transparent;"
                       text="SELECT LOCATION" textFill="NAVY">
                    <font><Font name="Nirmala UI Bold" size="14.0" /></font>
                </Label>
                <TextField fx:id="locationField" layoutX="38.0" layoutY="48.0"
                           prefWidth="200.0" promptText="Start typing a location..."
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #000080;" />

                <Label layoutX="271.0" layoutY="14.0" prefHeight="34.0" prefWidth="145.0"
                       style="-fx-background-color: transparent;"
                       text="CHECK-IN DATE" textFill="NAVY">
                    <font><Font name="Nirmala UI Bold" size="14.0" /></font>
                </Label>
                <DatePicker fx:id="checkin" layoutX="271.0" layoutY="48.0"
                            prefHeight="28.0" prefWidth="150.0" promptText="DD/MM/YYYY"
                            style="-fx-border-radius: 10; -fx-border-color: #BDC3C7;" />

                <Label layoutX="460.0" layoutY="14.0" prefHeight="34.0" prefWidth="145.0"
                       style="-fx-background-color: transparent;"
                       text="CHECK-OUT DATE" textFill="NAVY">
                    <font><Font name="Nirmala UI Bold" size="14.0" /></font>
                </Label>
                <DatePicker fx:id="checkout" layoutX="460.0" layoutY="48.0"
                            prefHeight="28.0" prefWidth="150.0" promptText="DD/MM/YYYY"
                            style="-fx-border-radius: 10; -fx-border-color: #BDC3C7;" />

                <Button fx:id="searchButton" layoutX="675.0" layoutY="30.0"
                        mnemonicParsing="false" onAction="#handleSearch"
                        prefHeight="50.0" prefWidth="100.0"
                        style="-fx-background-color: #fad102; -fx-background-radius: 5; -fx-text-fill: #000080; -fx-font-weight: bold;"
                        text="SEARCH">
                    <font><Font name="Arial" size="12.0" /></font>
                </Button>

            </children>
        </AnchorPane>

        <!-- Hotel Results Area -->
        <ScrollPane fx:id="hotellistcontainer" layoutY="197.0"
                    prefHeight="403.0" prefWidth="800.0"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: #E5E4E2; -fx-background: #E5E4E2;">
            <content>
                <VBox fx:id="cardContainer" prefWidth="780.0" spacing="12"
                      style="-fx-background-color: #E5E4E2; -fx-padding: 14 10 14 10;">
                    <!-- Status Label for loading / error -->
                    <Label fx:id="statusLabel" text="Searching for hotels..."
                           wrapText="true" prefWidth="760.0" alignment="CENTER"
                           style="-fx-text-fill: #555555; -fx-padding: 40 0 0 0;">
                        <font><Font name="Nirmala UI" size="14.0" /></font>
                    </Label>
                </VBox>
            </content>
        </ScrollPane>

    </children>
</AnchorPane>