                <Label layoutX="271.0" layoutY="14.0" prefHeight="34.0" prefWidth="145.0" style="-fx-background-color: transparent;" text="CHECK-IN DATE" textFill="NAVY">
                    <font><Font name="Nirmala UI Bold" size="14.0" /></font>
