<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:id="hotelCard"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel_lagbe.client.controllers.HotelCardController"
      prefHeight="160.0"
      prefWidth="760.0"
      spacing="15"
      style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);"
      alignment="CENTER_LEFT">

<!--    &lt;!&ndash; Hotel Photo &ndash;&gt;-->
<!--    <ImageView fx:id="hotelImageView"-->
<!--               fitWidth="190"-->
<!--               fitHeight="160"-->
<!--               preserveRatio="false"-->
<!--               style="-fx-background-radius: 12 0 0 12;" />-->
    <!-- Hotel Photo - Optimized for performance -->
    <ImageView fx:id="hotelImageView"
               fitWidth="190"
               fitHeight="160"
               preserveRatio="true"
               smooth="true"
               style="-fx-background-radius: 12 0 0 12;" />

    <!-- Hotel Details -->
    <VBox prefWidth="400.0" spacing="8" style="-fx-padding: 16 10 16 12;">
        <Label fx:id="hotelNameLabel" text="Hotel Name" style="-fx-text-fill: #000080; -fx-font-weight: bold;">
            <font><Font name="Nirmala UI Bold" size="15.5" /></font>
        </Label>

        <Label fx:id="hotelAddressLabel" text="Address will appear here" wrapText="true" style="-fx-text-fill: #555555;">
            <font><Font name="Nirmala UI" size="11.5" /></font>
        </Label>

        <Label fx:id="hotelRatingLabel" text="⭐ Rating" style="-fx-text-fill: #333333;">
            <font><Font name="Nirmala UI" size="12.5" /></font>
        </Label>

        <Label fx:id="hotelStatusLabel" text="Open Now" style="-fx-text-fill: #27AE60;">
            <font><Font name="Nirmala UI" size="11.5" /></font>
        </Label>
    </VBox>

    <!-- Price and Button -->
    <VBox prefWidth="150.0" alignment="CENTER" spacing="15" style="-fx-padding: 16;">


<!--        <Button fx:id="viewDetailsButton"-->
<!--                text="View Details"-->
<!--                prefWidth="135"-->
<!--                prefHeight="42"-->
<!--                onAction="#handleViewDetails"-->
<!--                style="-fx-background-color: #fad102; -fx-text-fill: #000080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;">-->
<!--            <font><Font name="Nirmala UI Bold" size="13.0" /></font>-->
<!--        </Button>-->
        <Button fx:id="viewDetailsButton"
                text="View Details"
                prefWidth="135"
                prefHeight="42"
                onAction="#handleViewDetails"
                style="-fx-background-color: #000080;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 20;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 6, 0, 2, 2);">
            <font><Font name="Nirmala UI Bold" size="13.0" /></font>
        </Button>
    </VBox>

</HBox>